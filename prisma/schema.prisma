generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Student {
  id              String   @id @default(cuid())
  name            String
  section         String
  rollNumber      String?
  teacherName     String?
  testId          String   @unique
  difficultyLevel String?  @default("Beginner")
  createdAt       DateTime @default(now())
  results         Result[]
}

model Question {
  id            String   @id @default(cuid())
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String
  level         String   @default("Beginner")
  createdAt     DateTime @default(now())
}

model Result {
  id             String   @id @default(cuid())
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  totalMarks     Int
  totalQuestions Int
  percentage     Float
  timeTaken      String
  answers        Json
  cheatingCount  Int      @default(0)
  submittedAt    DateTime @default(now())
}
